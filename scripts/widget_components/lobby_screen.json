{
  "id": "lobby_screen",
  "name": "Lobby Screen",
  "category": "multiplayer",
  "description": "Player list, map preview, settings, start button",
  "default_anchor": "Fill",
  "default_offset": [
    0,
    0
  ],
  "default_size": [
    0,
    0
  ],
  "variables": [],
  "options": {
    "is_host": {
      "type": "bool",
      "default": false
    }
  },
  "tree": {
    "type": "HBOX",
    "name": "LobbyRoot",
    "properties": {
      "spacing": "16"
    },
    "children": [
      {
        "type": "VBOX",
        "name": "PlayerList",
        "properties": {
          "spacing": "4"
        },
        "children": [
          {
            "type": "TEXT",
            "name": "PlayersTitle",
            "properties": {
              "text": "PLAYERS",
              "font_size": "16",
              "color": "$text",
              "bold": "true"
            }
          },
          {
            "type": "HBOX",
            "name": "P1Row",
            "properties": {
              "spacing": "6"
            },
            "children": [
              {
                "type": "TEXT",
                "name": "P1Ready",
                "properties": {
                  "text": "BIND:\"{P1Ready}\"",
                  "font_size": "14",
                  "color": "$accent"
                }
              },
              {
                "type": "TEXT",
                "name": "P1Name",
                "properties": {
                  "text": "BIND:\"{Player1Name}\"",
                  "font_size": "14",
                  "color": "$text"
                }
              }
            ]
          }
        ]
      },
      {
        "type": "VBOX",
        "name": "MapPanel",
        "properties": {
          "spacing": "8"
        },
        "children": [
          {
            "type": "IMAGE",
            "name": "MapThumb",
            "properties": {
              "tint": "$surface",
              "size_x": "200",
              "size_y": "120"
            }
          },
          {
            "type": "TEXT",
            "name": "MapName",
            "properties": {
              "text": "BIND:\"{MapName}\"",
              "font_size": "16",
              "color": "$text",
              "justification": "Center"
            }
          },
          {
            "type": "BUTTON",
            "name": "StartBtn",
            "properties": {
              "text": "START GAME",
              "font_size": "16"
            }
          }
        ]
      }
    ]
  }
}