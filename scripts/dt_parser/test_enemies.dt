DATATABLE: DT_Enemies
STRUCT: FEnemyData

COLUMN DisplayName: String
COLUMN MaxHealth: Float
COLUMN Damage: Float
COLUMN MoveSpeed: Float = 300.0
COLUMN DetectionRange: Float = 1000.0
COLUMN AttackRange: Float = 200.0
COLUMN XPReward: Int = 10
COLUMN IsFlying: Bool = false

ROW Goblin: "Goblin", 50.0, 8.0, 400.0, 800.0, 150.0, 15, false
ROW Skeleton: "Skeleton", 80.0, 12.0, 250.0, 600.0, 200.0, 25, false
ROW Dragon: "Dragon", 500.0, 50.0, 200.0, 2000.0, 500.0, 500, true
ROW Slime: "Slime", 20.0, 3.0, 150.0, 400.0, 100.0, 5, false
ROW Ghost: "Ghost", 60.0, 15.0, 350.0, 1200.0, 250.0, 30, true
