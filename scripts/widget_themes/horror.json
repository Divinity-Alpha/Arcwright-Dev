{
  "name": "Horror",
  "description": "Horror theme — dark blood red, sickly green, distressed edges, unsettling flicker",
  "version": "1.0",

  "colors": {
    "primary": "#6B0000",
    "secondary": "#440000",
    "accent": "#4A6B2A",
    "warning": "#8B6B00",
    "danger": "#880000",

    "panel_bg": "#080808",
    "card_bg": "#101010",
    "surface": "#181410",

    "text": "#C8B8A8",
    "text_secondary": "#887868",
    "text_muted": "#504038",

    "border": "#6B000050",
    "divider": "#6B000030",

    "health": "#6B0000",
    "health_low": "#440000",
    "mana": "#2A4A6B",
    "stamina": "#8B6B00",
    "xp": "#4A6B2A",

    "shadow": "rgba(0,0,0,0.7)"
  },

  "fonts": {
    "heading": {"family": "Special Elite", "weight": "Regular"},
    "body": {"family": "Nosifer", "weight": "Regular"},
    "mono": {"family": "Creepster", "weight": "Regular"},
    "ui": {"family": "Special Elite", "weight": "Regular"}
  },

  "sizes": {
    "h1": 36,
    "h2": 28,
    "h3": 22,
    "h4": 18,
    "body": 16,
    "small": 13,
    "tiny": 11,
    "icon_small": 24,
    "icon_medium": 32,
    "icon_large": 48,
    "corner_radius": 0,
    "border_width": 2,
    "spacing_xs": 4,
    "spacing_sm": 8,
    "spacing_md": 14,
    "spacing_lg": 22,
    "spacing_xl": 30
  },

  "defaults": {
    "TEXT": {
      "color": "#C8B8A8",
      "font_size": 16,
      "font": "Special Elite"
    },
    "PROGRESS_BAR": {
      "fill_color": "#6B0000",
      "bar_color": "#181410",
      "percent": 100
    },
    "BUTTON": {
      "font_size": 16,
      "normal_color": "#6B0000",
      "hovered_color": "#881111",
      "pressed_color": "#440000"
    },
    "BORDER": {
      "border_color": "#6B000050",
      "corner_radius": 0,
      "background": "#101010"
    },
    "CANVAS": {},
    "VBOX": {
      "spacing": 8
    },
    "HBOX": {
      "spacing": 8
    }
  }
}
