// ============================================================
// Variable creation
// ============================================================

void FBlueprintBuilder::CreateBlueprintVariables(UBlueprint* BP, const TArray<FDSLVariable>& Variables)
{
	for (const FDSLVariable& Var : Variables)
	{
		FEdGraphPinType PinType = GetPinTypeFromString(Var.Type);
		const bool bSuccess = FBlueprintEditorUtils::AddMemberVariable(BP, FName(*Var.Name), PinType);

		if (bSuccess && !Var.DefaultValue.IsEmpty())
		{
			// Set default value
			FProperty* Prop = BP->GeneratedClass->FindPropertyByName(FName(*Var.Name));
			if (Prop)
			{
				UE_LOG(LogTemp, Verbose, TEXT("BlueprintLLM: Created variable %s : %s = %s"),
					*Var.Name, *Var.Type, *Var.DefaultValue);
			}
		}
	}
}

// ============================================================
// Connection wiring
// ============================================================

bool FBlueprintBuilder::ConnectPins(
	const TMap<FString, UEdGraphNode*>& NodeMap,
	const TArray<FDSLConnection>& Connections)
{
	int32 SuccessCount = 0;
	int32 FailCount = 0;

	for (const FDSLConnection& Conn : Connections)
	{
		// Skip literal data connections for now
		if (Conn.Type == TEXT("data_literal"))
		{
			continue;
		}

		UEdGraphNode* const* SrcNodePtr = NodeMap.Find(Conn.SourceNode);
		UEdGraphNode* const* DstNodePtr = NodeMap.Find(Conn.TargetNode);

		if (!SrcNodePtr || !DstNodePtr)
		{
			UE_LOG(LogTemp, Warning, TEXT("BlueprintLLM: Connection refs unknown node: %s -> %s"),
				*Conn.SourceNode, *Conn.TargetNode);
			FailCount++;
			continue;
		}

		UEdGraphNode* SrcNode = *SrcNodePtr;
		UEdGraphNode* DstNode = *DstNodePtr;

		UEdGraphPin* SrcPin = FindPinByDSLName(SrcNode, Conn.SourcePin, EGPD_Output);
		UEdGraphPin* DstPin = FindPinByDSLName(DstNode, Conn.TargetPin, EGPD_Input);

		if (SrcPin && DstPin)
		{
			// Use Schema's TryCreateConnection — it auto-inserts conversion nodes (e.g. Float→String)
			const UEdGraphSchema_K2* Schema = GetDefault<UEdGraphSchema_K2>();
			bool bConnected = Schema->TryCreateConnection(SrcPin, DstPin);
			if (bConnected)
			{
				SuccessCount++;
			}
			else
			{
				// Fallback to direct link
				SrcPin->MakeLinkTo(DstPin);
				SuccessCount++;
			}
		}
		else
		{
			// Log available pins to help debug
			FString SrcPins, DstPins;
			for (UEdGraphPin* P : SrcNode->Pins) { if (P->Direction == EGPD_Output) { SrcPins += P->PinName.ToString() + TEXT(" "); } }
			for (UEdGraphPin* P : DstNode->Pins) { if (P->Direction == EGPD_Input) { DstPins += P->PinName.ToString() + TEXT(" "); } }

			UE_LOG(LogTemp, Warning, TEXT("BlueprintLLM: Pin not found: %s.%s(%s) -> %s.%s(%s) | SrcOuts=[%s] DstIns=[%s]"),
				*Conn.SourceNode, *Conn.SourcePin, SrcPin ? TEXT("OK") : TEXT("MISSING"),
				*Conn.TargetNode, *Conn.TargetPin, DstPin ? TEXT("OK") : TEXT("MISSING"),
				*SrcPins.TrimEnd(), *DstPins.TrimEnd());
			FailCount++;
		}
	}

	UE_LOG(LogTemp, Log, TEXT("BlueprintLLM: Wired %d/%d connections (%d failed)"),
		SuccessCount, SuccessCount + FailCount, FailCount);

	return FailCount == 0;
}

UEdGraphPin* FBlueprintBuilder::FindPinByDSLName(UEdGraphNode* Node, const FString& DSLName, EEdGraphPinDirection Direction)
{
	if (!Node) return nullptr;

	// 1. Exact match
	UEdGraphPin* Pin = Node->FindPin(FName(*DSLName), Direction);
	if (Pin) return Pin;

	// 2. Also try without direction constraint (some pins have weird direction)
	Pin = Node->FindPin(FName(*DSLName));
	if (Pin) return Pin;

	// 3. Known DSL-to-UE pin name aliases
	static const TMap<FString, TArray<FString>> PinAliases = {
		// Exec pins
		{ TEXT("Execute"),      { TEXT("execute"), TEXT("exec") } },
		{ TEXT("Then"),         { TEXT("then") } },
		{ TEXT("True"),         { TEXT("true") } },
		{ TEXT("False"),        { TEXT("false") } },

		// Branch condition
		{ TEXT("Condition"),    { TEXT("Condition"), TEXT("bCondition"), TEXT("bNotCondition") } },

		// Data pins - common short names from DSL
		{ TEXT("I"),            { TEXT("InString"), TEXT("InputObject"), TEXT("Object"), TEXT("Input") } },
		{ TEXT("ReturnValue"),  { TEXT("ReturnValue"), TEXT("bReturnValue") } },

		// PrintString
		{ TEXT("InString"),     { TEXT("InString"), TEXT("In String"), TEXT("InStr") } },

		// Cast pins
		{ TEXT("Object"),       { TEXT("Object"), TEXT("ObjectToCast") } },
		{ TEXT("CastSucceeded"),{ TEXT("then 0"), TEXT("CastSucceeded") } },
		{ TEXT("CastFailed"),   { TEXT("CastFail"), TEXT("then 1") } },

		// InputAction pins
		{ TEXT("Pressed"),      { TEXT("Pressed"), TEXT("pressed") } },
		{ TEXT("Released"),     { TEXT("Released"), TEXT("released") } },

		// IsValid output
		{ TEXT("IsValid"),      { TEXT("IsValid"), TEXT("ReturnValue"), TEXT("bIsValid") } },
	};

	// Try aliases
	if (const TArray<FString>* Aliases = PinAliases.Find(DSLName))
	{
		for (const FString& Alias : *Aliases)
		{
			Pin = Node->FindPin(FName(*Alias), Direction);
			if (Pin) return Pin;
			Pin = Node->FindPin(FName(*Alias));
			if (Pin) return Pin;
		}
	}

	// 4. Special case: "Value" on VariableGet/Set nodes - the pin name is the variable name
	if (DSLName == TEXT("Value"))
	{
		for (UEdGraphPin* P : Node->Pins)
		{
			if (P->Direction == Direction &&
				P->PinType.PinCategory != UEdGraphSchema_K2::PC_Exec &&
				P->PinName != UEdGraphSchema_K2::PN_Self &&
				P->PinName.ToString() != TEXT("WorldContextObject"))
			{
				return P;
			}
		}
	}

	// 5. Special case: Sequence output pins "A","B","C"... -> try many UE naming conventions
	if (DSLName.Len() == 1 && DSLName[0] >= 'A' && DSLName[0] <= 'F')
	{
		int32 Index = DSLName[0] - 'A';

		// Try all known Sequence pin name formats
		TArray<FString> SeqNames = {
			FString::Printf(TEXT("then %d"), Index),
			FString::Printf(TEXT("Then %d"), Index),
			FString::Printf(TEXT("Out_%d"), Index),
			FString::Printf(TEXT("out_%d"), Index),
			FString::Printf(TEXT("Out %d"), Index),
			FString::Printf(TEXT("Output_%d"), Index),
			FString::Printf(TEXT("%d"), Index),
		};

		for (const FString& Name : SeqNames)
		{
			Pin = Node->FindPin(FName(*Name), Direction);
			if (Pin) return Pin;
			Pin = Node->FindPin(FName(*Name));
			if (Pin) return Pin;
		}

		// Also try: just pick the Nth exec output pin
		int32 ExecOutCount = 0;
		for (UEdGraphPin* P : Node->Pins)
		{
			if (P->Direction == EGPD_Output && P->PinType.PinCategory == UEdGraphSchema_K2::PC_Exec)
			{
				if (ExecOutCount == Index)
				{
					return P;
				}
				ExecOutCount++;
			}
		}
	}

	// 5a. Special case: "Out_0", "Out_1", "Out_2"... pattern (MultiGate, etc.)
	if (DSLName.StartsWith(TEXT("Out_")) || DSLName.StartsWith(TEXT("out_")))
	{
		FString IndexStr = DSLName.RightChop(4);
		if (IndexStr.IsNumeric())
		{
			int32 Index = FCString::Atoi(*IndexStr);

			// Try exact match first (already tried above, but be thorough)
			TArray<FString> OutNames = {
				FString::Printf(TEXT("Out_%d"), Index),
				FString::Printf(TEXT("out_%d"), Index),
				FString::Printf(TEXT("Out %d"), Index),
				FString::Printf(TEXT("then %d"), Index),
				FString::Printf(TEXT("Then %d"), Index),
				FString::Printf(TEXT("%d"), Index),
			};

			for (const FString& Name : OutNames)
			{
				Pin = Node->FindPin(FName(*Name), Direction);
				if (Pin) return Pin;
				Pin = Node->FindPin(FName(*Name));
				if (Pin) return Pin;
			}

			// Fallback: pick the Nth exec output pin
			int32 ExecOutCount = 0;
			for (UEdGraphPin* P : Node->Pins)
			{
				if (P->Direction == EGPD_Output && P->PinType.PinCategory == UEdGraphSchema_K2::PC_Exec)
				{
					if (ExecOutCount == Index)
					{
						return P;
					}
					ExecOutCount++;
				}
			}
		}
	}

	// 5b. Special case: "C" as Branch condition pin
	if (DSLName == TEXT("C"))
	{
		Pin = Node->FindPin(TEXT("Condition"), Direction);
		if (Pin) return Pin;
		Pin = Node->FindPin(TEXT("bCondition"), Direction);
		if (Pin) return Pin;
	}

	// 5c. Special case: InputAction "Pressed"/"Released" — find Nth exec output
	if (DSLName == TEXT("Pressed"))
	{
		// Pressed is typically the first exec output pin
		int32 ExecIdx = 0;
		for (UEdGraphPin* P : Node->Pins)
		{
			if (P->Direction == EGPD_Output && P->PinType.PinCategory == UEdGraphSchema_K2::PC_Exec)
			{
				if (ExecIdx == 0) return P;
				ExecIdx++;
			}
		}
	}
	if (DSLName == TEXT("Released"))
	{
		// Released is typically the second exec output pin
		int32 ExecIdx = 0;
		for (UEdGraphPin* P : Node->Pins)
		{
			if (P->Direction == EGPD_Output && P->PinType.PinCategory == UEdGraphSchema_K2::PC_Exec)
			{
				if (ExecIdx == 1) return P;
				ExecIdx++;
			}
		}
	}

	// 6. Special case: "True"/"False" on Branch -> might be "then"/"else" in UE
	if (DSLName == TEXT("True"))
	{
		Pin = Node->FindPin(UEdGraphSchema_K2::PN_Then, Direction);
		if (Pin) return Pin;
		// Also try the raw text variations
		Pin = Node->FindPin(FName(TEXT("True")), Direction);
		if (Pin) return Pin;
	}
	if (DSLName == TEXT("False"))
	{
		Pin = Node->FindPin(UEdGraphSchema_K2::PN_Else, Direction);
		if (Pin) return Pin;
		Pin = Node->FindPin(FName(TEXT("False")), Direction);
		if (Pin) return Pin;
	}

	// 7. Special case: exec input "Execute" -> try UE's standard exec pin name, then first exec input
	if (DSLName == TEXT("Execute"))
	{
		Pin = Node->FindPin(UEdGraphSchema_K2::PN_Execute, Direction);
		if (Pin) return Pin;

		// Try common macro input pin names
		Pin = Node->FindPin(TEXT("In"), Direction);
		if (Pin) return Pin;
		Pin = Node->FindPin(TEXT("Input"), Direction);
		if (Pin) return Pin;

		// Fallback: grab the first exec input pin
		for (UEdGraphPin* P : Node->Pins)
		{
			if (P->Direction == EGPD_Input && P->PinType.PinCategory == UEdGraphSchema_K2::PC_Exec)
			{
				return P;
			}
		}
	}

	// 8. Special case: exec output "Then" -> try UE's standard then pin name, then first exec output
	if (DSLName == TEXT("Then"))
	{
		Pin = Node->FindPin(UEdGraphSchema_K2::PN_Then, Direction);
		if (Pin) return Pin;

		// Try common macro output pin names
		Pin = Node->FindPin(TEXT("Out"), Direction);
		if (Pin) return Pin;
		Pin = Node->FindPin(TEXT("Output"), Direction);
		if (Pin) return Pin;

		// Fallback: grab the first exec output pin
		for (UEdGraphPin* P : Node->Pins)
		{
			if (P->Direction == EGPD_Output && P->PinType.PinCategory == UEdGraphSchema_K2::PC_Exec)
			{
				return P;
			}
		}
	}

	// 9. Special case: "ReturnValue"
	if (DSLName == TEXT("ReturnValue"))
	{
		Pin = Node->FindPin(UEdGraphSchema_K2::PN_ReturnValue, Direction);
		if (Pin) return Pin;
	}

	// 10. Case-insensitive search as last resort
	for (UEdGraphPin* P : Node->Pins)
	{
		if (P->PinName.ToString().Equals(DSLName, ESearchCase::IgnoreCase))
		{
			if (Direction == EGPD_MAX || P->Direction == Direction)
			{
				return P;
			}
		}
	}

	// 11. Substring match - if DSL pin name is contained in UE pin name or vice versa
	for (UEdGraphPin* P : Node->Pins)
	{
		if (P->Direction == Direction || Direction == EGPD_MAX)
		{
			FString UEName = P->PinName.ToString();
			if (UEName.Contains(DSLName) || DSLName.Contains(UEName))
			{
				// Skip exec, self, and WorldContextObject pins
				if (P->PinType.PinCategory == UEdGraphSchema_K2::PC_Exec ||
					P->PinName == UEdGraphSchema_K2::PN_Self ||
					P->PinName.ToString() == TEXT("WorldContextObject"))
				{
					continue;
				}
				return P;
			}
		}
	}

	return nullptr;
}

