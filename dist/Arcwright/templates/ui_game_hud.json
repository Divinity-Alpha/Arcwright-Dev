{
  "template_id": "ui_game_hud",
  "name": "Game HUD",
  "category": "ui",
  "description": "A heads-up display with score, health bar, wave counter, and message area. Uses CanvasPanel root with positioned TextBlocks and ProgressBar.",
  "version": "1.0",
  "proven_in": "Arena Collector",
  "customizable": {
    "widget_name": "WBP_GameHUD",
    "show_score": "Include score display (default: true)",
    "show_health": "Include health bar (default: true)",
    "show_wave": "Include wave counter (default: true)",
    "show_messages": "Include message area (default: true)"
  },
  "widget_tree": {
    "create": "WBP_GameHUD",
    "widgets": [
      {
        "type": "CanvasPanel",
        "name": "RootPanel",
        "parent": null
      },
      {
        "type": "TextBlock",
        "name": "ScoreLabel",
        "parent": "RootPanel",
        "properties": {
          "text": "Score: 0",
          "font_size": 28,
          "color": {"r": 1, "g": 0.9, "b": 0, "a": 1},
          "slot_position": {"x": 40, "y": 30}
        }
      },
      {
        "type": "ProgressBar",
        "name": "HealthBar",
        "parent": "RootPanel",
        "properties": {
          "percent": 1.0,
          "fill_color": {"r": 0, "g": 1, "b": 0, "a": 1},
          "slot_position": {"x": 500, "y": 25},
          "slot_size": {"x": 300, "y": 30}
        }
      },
      {
        "type": "TextBlock",
        "name": "HealthLabel",
        "parent": "RootPanel",
        "properties": {
          "text": "Health: 100",
          "font_size": 18,
          "color": {"r": 1, "g": 1, "b": 1, "a": 1},
          "slot_position": {"x": 580, "y": 5}
        }
      },
      {
        "type": "TextBlock",
        "name": "WaveLabel",
        "parent": "RootPanel",
        "properties": {
          "text": "Wave: 1",
          "font_size": 24,
          "color": {"r": 0.8, "g": 0.8, "b": 1, "a": 1},
          "slot_position": {"x": 1100, "y": 30}
        }
      },
      {
        "type": "TextBlock",
        "name": "MessageText",
        "parent": "RootPanel",
        "properties": {
          "text": "",
          "font_size": 32,
          "color": {"r": 1, "g": 1, "b": 0, "a": 1},
          "slot_position": {"x": 500, "y": 650}
        }
      }
    ]
  },
  "hud_manager_dsl": "BLUEPRINT: {{manager_name|BP_ArenaManager}}\nPARENT: Actor\n\nVAR Score: Int = 0\nVAR Health: Float = 100.0\nVAR Wave: Int = 1\n\nGRAPH: EventGraph\n\nNODE n1: Event_BeginPlay\nNODE n2: CreateWidget [WidgetClass=WBP_GameHUD]\nNODE n3: AddToViewport\nNODE n4: PrintString [InString=\"Game Started!\"]\n\nEXEC n1.Then -> n2.Execute\nEXEC n2.Then -> n3.Execute\nEXEC n3.Then -> n4.Execute\n\nDATA n2.ReturnValue -> n3.Target [Widget]"
}
